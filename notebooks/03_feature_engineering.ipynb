 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# 03 — Feature Engineering\n",
    "\n",
    "Build the full feature matrix used by both ML models:\n",
    "\n",
    "- Temporal features (month, season, Ramadan, holidays)\n",
    "- Lag features (1m, 3m, 6m, 12m)\n",
    "- Rolling statistics (3m and 6m windows)\n",
    "- Price vs. national mean ratio\n",
    "- Normalised price column for LSTM"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import sys; sys.path.insert(0, '..')\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "\n",
    "from src.data_ingestion.wfp_connector import WFPConnector\n",
    "from src.preprocessing.data_cleaner import DataCleaner\n",
    "from src.preprocessing.feature_engineering import FeatureEngineer\n",
    "from src.utils.helpers import load_config\n",
    "\n",
    "config = load_config('../config/config.yaml')\n",
    "\n",
    "raw   = WFPConnector(config=config).fetch_price_data()\n",
    "clean = DataCleaner(config=config).clean(raw)\n",
    "print(f'Clean data: {clean.shape}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Run Feature Engineering ───────────────────────────────────\n",
    "fe = FeatureEngineer(config=config)\n",
    "features = fe.build_features(clean)\n",
    "\n",
    "print('New features added:')\n",
    "new_cols = [c for c in features.columns if c not in clean.columns]\n",
    "print(new_cols)\n",
    "features.head(3)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Missing values after engineering ─────────────────────────\n",
    "missing_pct = features[new_cols].isna().mean() * 100\n",
    "print('Missing % per feature:')\n",
    "print(missing_pct.sort_values(ascending=False).head(15))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Feature Correlation with Price ───────────────────────────\n",
    "num_features = features.select_dtypes(include='number').columns.tolist()\n",
    "corr_with_price = features[num_features].corr()['price'].drop('price').abs().sort_values(ascending=False)\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(10, 5))\n",
    "corr_with_price.head(20).plot(kind='barh', ax=ax, color='#1565c0', alpha=0.85)\n",
    "ax.set_title('Top 20 Features — Corrélation |r| avec le Prix', fontsize=13, fontweight='bold')\n",
    "ax.set_xlabel('|Corrélation|')\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Seasonal Pattern (is_ramadan) ─────────────────────────────\n",
    "ramadan_mean = features.groupby('is_ramadan')['price'].mean()\n",
    "print('Mean price — Hors Ramadan vs Ramadan:')\n",
    "print(ramadan_mean)\n",
    "print(f'Uplift: {(ramadan_mean[1]/ramadan_mean[0] - 1)*100:.1f}%')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Save engineered features ──────────────────────────────────\n",
    "out = fe.build_and_save(clean, filename='features.parquet')\n",
    "print(f'Saved → {out}')"
   ]
  }
 ],
