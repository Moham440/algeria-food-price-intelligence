# FAO API (no key required — public)
FAO_API_BASE_URL=https://fenixservices.fao.org/faostat/api/v1

# WFP / HDX (optional API key for higher rate limits)
HDX_API_KEY=

# Redis (optional caching)
REDIS_URL=redis://localhost:6379

# Notifications (optional)
SENDGRID_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
ALERT_EMAIL_TO=
ALERT_PHONE_TO=

# MLflow
MLFLOW_TRACKING_URI=sqlite:///mlflow.db
